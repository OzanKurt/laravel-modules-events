includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 8
    paths:
        - src
    tmpDir: build/phpstan
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Traits in this package are consumed by downstream KurtModules packages,
        # so PHPStan's "trait used zero times" check would otherwise flag them.
        - identifier: trait.unused
